# Environment — copy to `.env` and fill in before `docker compose up`
#   cp .env.example .env

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change-me-root-password
DB_NAME=roommate
DB_USER=rmmt
DB_PASSWORD=change-me-db-password

# ---------- API (rmmt-api / rmmt-api-task) ----------
# Used to sign student/admin JWT tokens
JWT_SECRET=change-me-long-random-string

# Optional: DeepSeek (or compatible) for AI roommate search
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# Matching v2 score blending (task worker)
MATCHING_V2_ALPHA=0.7
MATCHING_V2_BETA=0.3

# ---------- phpMyAdmin (optional profile: db-ui) ----------
# Only used when starting: docker compose --profile db-ui up -d phpmyadmin
# Must match how you open it in the browser (default is localhost-only :8081)
PMA_ABSOLUTE_URI=http://127.0.0.1:8081/
